# ============================================================================
# IDE-SPECIFIC (but may want to keep for team consistency)
# ============================================================================

# Uncomment if you DO want to version control IDE settings (not recommended):
# !.vscode/settings.json
# !.idea/runConfigurations/

# ============================================================================
# ALLOWED EXCEPTIONS (!) - These files SHOULD be tracked
# ============================================================================

# Keep source code
!src/
!src/**/*.py

# Keep notebooks (but not checkpoints)
!notebooks/
!notebooks/**/*.ipynb

# Keep documentation
!SRC_README.md
!INFRASTRUCTURE_SUMMARY.txt
!requirements.txt
!.gitignore
!README.md

# Keep configuration files
!config/
!config/**/*.yaml
!config/**/*.json

# Keep test files
!tests/
!tests/**/*.py

# ============================================================================
# END OF GITIGNORE
# ============================================================================
# This .gitignore is designed to:
# 1. Exclude all temporary Python/IDE files
# 2. Exclude large generated outputs (models, logs, results)
# 3. Exclude experiment runs (tensorboard, checkpoints)
# 4. Keep source code and documentation
# 5. Keep notebooks but exclude checkpoints
#
# Customize as needed for your team's workflow
# ============================================================================
